# MaNGOSWebV5 - AzerothCore CMS
# Copy this file to .env and fill in your values

# Server
PORT=3000
HOST=localhost
BASE_URL=http://localhost:3000

# Session
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars
SESSION_LIFETIME=2592000000

# CMS Database (mangosweb)
CMS_DB_HOST=192.168.1.117
CMS_DB_PORT=3306
CMS_DB_USER=acore
CMS_DB_PASS=acore
CMS_DB_NAME=mangosweb

# Auth Database (acore_auth)
AUTH_DB_HOST=192.168.1.117
AUTH_DB_PORT=3306
AUTH_DB_USER=acore
AUTH_DB_PASS=acore
AUTH_DB_NAME=acore_auth

# Characters Database (acore_characters)
CHAR_DB_HOST=192.168.1.117
CHAR_DB_PORT=3306
CHAR_DB_USER=acore
CHAR_DB_PASS=acore
CHAR_DB_NAME=acore_characters

# World Database (acore_world)
WORLD_DB_HOST=192.168.1.117
WORLD_DB_PORT=3306
WORLD_DB_USER=acore
WORLD_DB_PASS=acore
WORLD_DB_NAME=acore_world

# SOAP (AzerothCore remote commands)
SOAP_HOST=127.0.0.1
SOAP_PORT=7878
SOAP_USER=admin
SOAP_PASS=admin

# Email (SMTP)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=
SMTP_PASS=
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=MaNGOSWebV5

# reCAPTCHA
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# PayPal
PAYPAL_EMAIL=
PAYPAL_SANDBOX=true
