<!-- GM Commands — V4 Blizzlike Style -->
<div class="subheader-bar">
  <div class="sh-left"></div>
  <div class="sh-mid"><b>GM Commands</b></div>
  <div class="sh-right"></div>
</div>

<% if (!user || user.gmlevel < 3) { %>
  <p style="color:#c00; background:#200; padding:8px; border:1px solid #600;">Access denied. GM privileges required.</p>
<% } else { %>
  <table class="blizz-table" style="width:100%; margin-bottom:10px;">
    <tr><th>Send Command</th></tr>
    <tr><td>
      <form method="POST" action="/server/commands" class="blizz-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <table cellspacing="0" cellpadding="0" style="width:100%;"><tr>
          <td style="width:140px; padding-right:6px;">
            <label>Realm</label>
            <select name="realmId" style="width:100%; padding:4px; background:#0a1929; color:#ccc; border:1px solid #1a3a5c;">
              <% realms.forEach(r => { %>
                <option value="<%= r.id %>"><%= r.name %></option>
              <% }) %>
            </select>
          </td>
          <td style="padding-right:6px;">
            <label>Command</label>
            <input type="text" name="command" placeholder=".server info" required style="width:100%;">
          </td>
          <td style="width:80px; vertical-align:bottom;">
            <button type="submit" class="btn-blizz" style="width:100%; margin-top:18px;">Execute</button>
          </td>
        </tr></table>
      </form>
    </td></tr>
  </table>

  <% if (typeof result !== 'undefined' && result) { %>
    <table class="blizz-table" style="width:100%; margin-bottom:10px;">
      <tr><th>Result</th></tr>
      <tr><td><pre style="color:#6f6; background:#000; padding:8px; margin:0; white-space:pre-wrap; font-family:monospace;"><%= result %></pre></td></tr>
    </table>
  <% } %>

  <table class="blizz-table" style="width:100%;">
    <tr><th colspan="2">Common Commands</th></tr>
    <tr style="background:#05374a; color:#d0a803;"><td><b>Command</b></td><td><b>Description</b></td></tr>
    <tr class="pvpboxrow"><td style="font-family:monospace; color:#6f6;">.server info</td><td>Show server information</td></tr>
    <tr class="pvpboxrowalt"><td style="font-family:monospace; color:#6f6;">.server shutdown [seconds]</td><td>Shutdown server</td></tr>
    <tr class="pvpboxrow"><td style="font-family:monospace; color:#6f6;">.account create [name] [pass]</td><td>Create account</td></tr>
    <tr class="pvpboxrowalt"><td style="font-family:monospace; color:#6f6;">.send items [player] "subject" "text" [itemId:count]</td><td>Send items</td></tr>
    <tr class="pvpboxrow"><td style="font-family:monospace; color:#6f6;">.send money [player] "subject" "text" [amount]</td><td>Send gold</td></tr>
    <tr class="pvpboxrowalt"><td style="font-family:monospace; color:#6f6;">.announce [message]</td><td>Server-wide announcement</td></tr>
    <tr class="pvpboxrow"><td style="font-family:monospace; color:#6f6;">.ban account [name] [duration] [reason]</td><td>Ban account</td></tr>
    <tr class="pvpboxrowalt"><td style="font-family:monospace; color:#6f6;">.unban account [name]</td><td>Unban account</td></tr>
    <tr class="pvpboxrow"><td style="font-family:monospace; color:#6f6;">.lookup item [name]</td><td>Search for items</td></tr>
  </table>
<% } %>
