
<!-- Players Online — V4 Blizzlike Style -->
<div class="subheader-bar">
  <div class="sh-left"></div>
  <div class="sh-mid"><b>Players Online (<%= players.length %>)</b></div>
  <div class="sh-right"></div>
</div>

<% if (typeof players !== 'undefined' && players.length) { %>
  <table class="blizz-table" style="width:100%;">
    <tr>
      <th>Name</th>
      <th>Race</th>
      <th>Class</th>
      <th>Level</th>
      <th>Zone</th>
      <th>Faction</th>
    </tr>
    <% players.forEach(function(p, i) { %>
      <tr class="<%= i % 2 === 0 ? 'pvpboxrow' : 'pvpboxrowalt' %> pvp-row">
        <td><b><%= p.name %></b></td>
        <td><%= Character.raceName(p.race) %></td>
        <td><%= Character.className(p.class) %></td>
        <td><%= p.level %></td>
        <td><%= p.zone %></td>
        <td>
          <span class="<%= Character.factionForRace(p.race) === 'Alliance' ? 'badge-alliance' : 'badge-horde' %>">
            <%= Character.factionForRace(p.race) %>
          </span>
        </td>
      </tr>
    <% }); %>
  </table>
<% } else { %>
  <p style="padding:10px; color:#333;">No players currently online.</p>
<% } %>
