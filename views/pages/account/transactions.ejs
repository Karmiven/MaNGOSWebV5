<!-- Transactions — V4 Blizzlike Style -->
<div class="subheader-bar">
  <div class="sh-left"></div>
  <div class="sh-mid"><b>My Transactions</b></div>
  <div class="sh-right"></div>
</div>

<p><b style="color:#d0a803;"><%= ext ? ext.web_points : 0 %></b> Web Points &nbsp;|&nbsp; Total Donated: <b style="color:#4a4;">$<%= ext ? ext.total_donations : '0.00' %></b></p>

<table class="blizz-table" style="width:100%;">
  <tr><th colspan="5">Transaction History</th></tr>
  <% if (transactions && transactions.length) { %>
    <tr style="background:#05374a; color:#d0a803;">
      <td><b>ID</b></td><td><b>Transaction</b></td><td><b>Amount</b></td><td><b>Status</b></td><td><b>Delivered</b></td>
    </tr>
    <% transactions.forEach((t, i) => { %>
      <tr class="<%= i % 2 === 0 ? 'pvpboxrow' : 'pvpboxrowalt' %>">
        <td><%= t.id %></td>
        <td style="font-size:11px;"><%= t.trans_id %></td>
        <td>$<%= t.amount %></td>
        <td><span style="color:<%= t.payment_status === 'Completed' ? '#4a4' : '#da4' %>;"><%= t.payment_status %></span></td>
        <td><%= t.item_given ? '✓' : '⏳' %></td>
      </tr>
    <% }) %>
  <% } else { %>
    <tr><td colspan="5" style="text-align:center; padding:30px; color:#888;">No transactions yet.</td></tr>
  <% } %>
</table>
