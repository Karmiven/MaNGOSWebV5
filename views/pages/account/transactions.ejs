<%
  var tp = typeof themePath !== 'undefined' ? themePath : '/themes/wotlk';
  var _purchases = typeof purchases !== 'undefined' ? purchases : [];
  var _transactions = typeof transactions !== 'undefined' ? transactions : [];
%>
<!-- Transactions — V4 Blizzlike Style -->
<br>
<%- include('../../partials/builddiv_start', { type: 0, title: 'My Transactions' }) %>

<style type="text/css">
  td.txRow1 { font-size: 0.85em; border-style: solid; border-width: 0px 1px 1px 0px; border-color: #D8BF95; padding: 5px 8px; }
  td.txRow2 { font-size: 0.85em; border-style: solid; border-width: 0px 1px 1px 0px; border-color: #D8BF95; background-color: #C3AD89; padding: 5px 8px; }
  td.rankingHeader { color: #C7C7C7; font-size: 10pt; font-family: arial,helvetica,sans-serif; font-weight: bold; background-color: #2E2D2B; border-style: solid; border-width: 1px; border-color: #5D5D5D #5D5D5D #1E1D1C #1E1D1C; padding: 3px;}
  .status-completed { color: #234303; font-weight: bold; }
  .status-failed { color: #cc2200; font-weight: bold; }
</style>

<div style="padding:5px 10px; margin-bottom:10px; font-size:12px; background:#e8dcc0; border:1px solid #c5a96a; border-radius:2px;">
  Balance: <b style="color:#1e4378;"><%= ext ? ext.web_points : 0 %></b> Web Points
  &nbsp;|&nbsp; Spent: <b style="color:#8b0000;"><%= ext ? ext.points_spent : 0 %></b>
  &nbsp;|&nbsp; Earned: <b style="color:#234303;"><%= ext ? ext.points_earned : 0 %></b>
</div>

<!-- Shop Purchases -->
<%- include('../../partials/subheader', { subheader: 'Shop Purchases (' + _purchases.length + ')' }) %>

<%- include('../../partials/metalborder_header') %>
<table cellpadding="3" cellspacing="0" width="100%">
<tbody>
  <tr>
    <td class="rankingHeader" align="center" nowrap="nowrap">#</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Item</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Qty</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Cost</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Character</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Status</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Date</td>
  </tr>
<% if (_purchases.length) { %>
  <% _purchases.forEach(function(p, idx) {
    var rowClass = (idx % 2 === 0) ? 'txRow1' : 'txRow2';
  %>
  <tr>
    <td class="<%= rowClass %>" align="center"><%= idx + 1 %></td>
    <td class="<%= rowClass %>">
      <b style="color: rgb(35, 67, 3);"><%= p.item_desc || 'Item' %></b>
      <% if (p.item_number) { %><span style="color:#888; font-size:10px;"> (ID: <%= p.item_number %>)</span><% } %>
    </td>
    <td class="<%= rowClass %>" align="center"><%= p.quantity || 1 %></td>
    <td class="<%= rowClass %>" align="center"><b style="color:#1e4378;"><%= p.wp_cost %> pts</b></td>
    <td class="<%= rowClass %>" align="center"><b><%= p.character_name %></b></td>
    <td class="<%= rowClass %>" align="center">
      <span class="status-<%= p.status %>"><%= p.status === 'completed' ? 'Delivered' : 'Failed' %></span>
    </td>
    <td class="<%= rowClass %>" align="center" style="font-size:10px;">
      <%= p.created_at ? new Date(p.created_at).toLocaleString('en-GB', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
    </td>
  </tr>
  <% }); %>
<% } else { %>
  <tr>
    <td class="txRow1" colspan="7" align="center" style="padding:15px; color:#888;">No shop purchases yet.</td>
  </tr>
<% } %>
</tbody>
</table>
<%- include('../../partials/metalborder_footer') %>

<br>

<!-- Donation Transactions -->
<%- include('../../partials/subheader', { subheader: 'Donation Transactions (' + _transactions.length + ')' }) %>

<%- include('../../partials/metalborder_header') %>
<table cellpadding="3" cellspacing="0" width="100%">
<tbody>
  <tr>
    <td class="rankingHeader" align="center" nowrap="nowrap">#</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Transaction ID</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Amount</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Status</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Delivered</td>
    <td class="rankingHeader" align="center" nowrap="nowrap">Date</td>
  </tr>
<% if (_transactions.length) { %>
  <% _transactions.forEach(function(t, idx) {
    var rowClass = (idx % 2 === 0) ? 'txRow1' : 'txRow2';
  %>
  <tr>
    <td class="<%= rowClass %>" align="center"><%= idx + 1 %></td>
    <td class="<%= rowClass %>" style="font-size:10px;"><%= t.trans_id %></td>
    <td class="<%= rowClass %>" align="center"><b style="color:#1e4378;">$<%= t.amount %></b></td>
    <td class="<%= rowClass %>" align="center">
      <span class="status-<%= t.payment_status === 'Completed' ? 'completed' : 'failed' %>"><%= t.payment_status %></span>
    </td>
    <td class="<%= rowClass %>" align="center"><%= t.item_given ? 'Yes' : 'Pending' %></td>
    <td class="<%= rowClass %>" align="center" style="font-size:10px;">
      <%= t.created_at ? new Date(t.created_at).toLocaleString('en-GB', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %>
    </td>
  </tr>
  <% }); %>
<% } else { %>
  <tr>
    <td class="txRow1" colspan="6" align="center" style="padding:15px; color:#888;">No donation transactions yet.</td>
  </tr>
<% } %>
</tbody>
</table>
<%- include('../../partials/metalborder_footer') %>

<%- include('../../partials/builddiv_end') %>
