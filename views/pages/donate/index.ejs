
<!-- Donate — V4 Blizzlike Style -->
<div class="subheader-bar">
  <div class="sh-left"></div>
  <div class="sh-mid"><b>Donate</b></div>
  <div class="sh-right"></div>
</div>

<p>Support the server by donating. You will receive Web Points that can be spent in the <a href="/shop">Item Shop</a>.</p>

<% if (typeof user !== 'undefined' && user) { %>
  <div class="flash-message flash-info">Your balance: <b><%= user.web_points || 0 %> Points</b></div>
<% } %>

<% if (typeof packages !== 'undefined' && packages && packages.length > 0) { %>
  <table class="blizz-table">
    <tr>
      <th>Package</th>
      <th>Points</th>
      <th>Price</th>
      <th>Action</th>
    </tr>
    <% packages.forEach(function(pkg) { %>
      <tr>
        <td><b><%= pkg.name %></b><% if (pkg.description) { %> <br><small style="color:#666;"><%= pkg.description %></small><% } %></td>
        <td style="color:#1e4378; font-weight:bold;"><%= pkg.points %></td>
        <td>$<%= parseFloat(pkg.price).toFixed(2) %> USD</td>
        <td>
          <% if (typeof user !== 'undefined' && user) { %>
            <form method="POST" action="/donate/checkout" style="display:inline;">
              <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <input type="hidden" name="packageId" value="<%= pkg.id %>">
              <input type="submit" value="Donate via PayPal" class="btn-blizz">
            </form>
          <% } else { %>
            <a href="/auth/login" class="btn-blizz">Login to Donate</a>
          <% } %>
        </td>
      </tr>
    <% }); %>
  </table>
<% } else { %>
  <p style="padding:10px; color:#333;">No donation packages available at this time.</p>
<% } %>
