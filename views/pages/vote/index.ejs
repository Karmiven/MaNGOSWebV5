
<!-- Vote — V4 Blizzlike Style -->
<div class="subheader-bar">
  <div class="sh-left"></div>
  <div class="sh-mid"><b>Vote for Us</b></div>
  <div class="sh-right"></div>
</div>

<p>Vote for our server on the sites below to earn Web Points! You can vote once every <b><%= typeof voteCooldown !== 'undefined' ? voteCooldown : 12 %> hours</b> per site.</p>

<% if (typeof user !== 'undefined' && user) { %>
  <div class="flash-message flash-info">Your balance: <b><%= user.web_points || 0 %> Points</b></div>
<% } %>

<% if (typeof sites !== 'undefined' && sites && sites.length > 0) { %>
  <table class="blizz-table">
    <tr>
      <th>Site</th>
      <th>Reward</th>
      <th>Action</th>
    </tr>
    <% sites.forEach(function(site) { %>
      <tr>
        <td>
          <b><%= site.name %></b>
          <% if (site.description) { %><br><small style="color:#666;"><%= site.description %></small><% } %>
        </td>
        <td style="color:#1e4378; font-weight:bold;">+<%= site.points_reward %> Points</td>
        <td>
          <% if (typeof user !== 'undefined' && user) { %>
            <% if (site.canVote) { %>
              <form method="POST" action="/vote" style="display:inline;">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <input type="hidden" name="siteId" value="<%= site.id %>">
                <input type="submit" value="Vote Now" class="btn-blizz" onclick="window.open('<%= site.url %>', '_blank')">
              </form>
            <% } else { %>
              <span style="color:#999;">Next vote: <%= site.nextVoteIn %></span>
            <% } %>
          <% } else { %>
            <a href="/auth/login" class="btn-blizz">Login to Vote</a>
          <% } %>
        </td>
      </tr>
    <% }); %>
  </table>
<% } else { %>
  <p style="padding:10px; color:#333;">No vote sites configured.</p>
<% } %>
