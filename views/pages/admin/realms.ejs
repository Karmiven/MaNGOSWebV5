<h3 class="mb-4">Realm Configuration <span class="badge bg-danger">Super Admin</span></h3>

<% if (realms && realms.length) { %>
  <% realms.forEach(r => { %>
    <% const cfg = configMap[r.id] || {}; %>
    <div class="card bg-dark border-secondary mb-4">
      <div class="card-header text-gold">#<%= r.id %> - <%= r.name %></div>
      <div class="card-body">
        <form method="POST" action="/admin/realms/update">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="realm_id" value="<%= r.id %>">

          <div class="form-check mb-3">
            <input type="checkbox" name="site_enabled" value="1" class="form-check-input" id="en-<%= r.id %>" <%= cfg.site_enabled ? 'checked' : '' %>>
            <label class="form-check-label" for="en-<%= r.id %>">Enabled on website</label>
          </div>

          <h6 class="text-gold mt-3">Character Database</h6>
          <div class="row g-2 mb-3">
            <div class="col-md-4"><input type="text" name="db_char_host" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Host" value="<%= cfg.db_char_host || '127.0.0.1' %>"></div>
            <div class="col-md-2"><input type="text" name="db_char_port" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Port" value="<%= cfg.db_char_port || '3306' %>"></div>
            <div class="col-md-2"><input type="text" name="db_char_name" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="DB Name" value="<%= cfg.db_char_name || '' %>"></div>
            <div class="col-md-2"><input type="text" name="db_char_user" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="User" value="<%= cfg.db_char_user || '' %>"></div>
            <div class="col-md-2"><input type="password" name="db_char_pass" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Pass" value="<%= cfg.db_char_pass || '' %>"></div>
          </div>

          <h6 class="text-gold mt-3">World Database</h6>
          <div class="row g-2 mb-3">
            <div class="col-md-4"><input type="text" name="db_world_host" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Host" value="<%= cfg.db_world_host || '127.0.0.1' %>"></div>
            <div class="col-md-2"><input type="text" name="db_world_port" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Port" value="<%= cfg.db_world_port || '3306' %>"></div>
            <div class="col-md-2"><input type="text" name="db_world_name" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="DB Name" value="<%= cfg.db_world_name || '' %>"></div>
            <div class="col-md-2"><input type="text" name="db_world_user" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="User" value="<%= cfg.db_world_user || '' %>"></div>
            <div class="col-md-2"><input type="password" name="db_world_pass" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Pass" value="<%= cfg.db_world_pass || '' %>"></div>
          </div>

          <h6 class="text-gold mt-3">SOAP / Remote Access</h6>
          <div class="row g-2 mb-3">
            <div class="col-md-3">
              <select name="ra_type" class="form-select form-select-sm bg-dark text-light border-secondary">
                <option value="1" <%= (cfg.ra_type||1)==1?'selected':'' %>>SOAP</option>
                <option value="0" <%= cfg.ra_type==0?'selected':'' %>>RA Console</option>
              </select>
            </div>
            <div class="col-md-3"><input type="number" name="ra_port" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Port" value="<%= cfg.ra_port || 7878 %>"></div>
            <div class="col-md-3"><input type="text" name="ra_user" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="User" value="<%= cfg.ra_user || '' %>"></div>
            <div class="col-md-3"><input type="password" name="ra_pass" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Pass" value="<%= cfg.ra_pass || '' %>"></div>
          </div>

          <button type="submit" class="btn btn-gold"><i class="fas fa-save me-1"></i>Save</button>
        </form>
      </div>
    </div>
  <% }) %>
<% } else { %>
  <div class="alert alert-info">No realms found in the auth database.</div>
<% } %>
