<h3 class="mb-4">Donate Packages</h3>

<!-- Add Package -->
<div class="card bg-dark border-secondary mb-4">
  <div class="card-header text-gold">Add Package</div>
  <div class="card-body">
    <form method="POST" action="/admin/donate/add">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="row g-2">
        <div class="col-md-4"><input type="text" name="desc" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Description" required></div>
        <div class="col-md-3"><input type="number" name="cost" step="0.01" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Cost (USD)" required></div>
        <div class="col-md-3"><input type="number" name="points" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Points" required></div>
        <div class="col-md-2"><button type="submit" class="btn btn-sm btn-gold w-100">Add</button></div>
      </div>
    </form>
  </div>
</div>

<!-- Packages Table -->
<div class="table-responsive">
  <table class="table table-dark table-hover table-sm">
    <thead><tr><th>ID</th><th>Description</th><th>Cost (USD)</th><th>Points</th><th>Actions</th></tr></thead>
    <tbody>
      <% if (packages && packages.length) { %>
        <% packages.forEach(pkg => { %>
          <tr>
            <td><%= pkg.id %></td>
            <td><%= pkg.desc %></td>
            <td>$<%= parseFloat(pkg.cost).toFixed(2) %></td>
            <td class="text-gold"><%= pkg.points %></td>
            <td>
              <button class="btn btn-sm btn-outline-gold me-1" data-bs-toggle="modal" data-bs-target="#edit-d-<%= pkg.id %>"><i class="fas fa-edit"></i></button>
              <form method="POST" action="/admin/donate/delete" class="d-inline" onsubmit="return confirm('Delete?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="id" value="<%= pkg.id %>">
                <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
              </form>
            </td>
          </tr>

          <div class="modal fade" id="edit-d-<%= pkg.id %>" tabindex="-1">
            <div class="modal-dialog">
              <div class="modal-content bg-dark text-light">
                <div class="modal-header border-secondary"><h5 class="modal-title text-gold">Edit Package</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <form method="POST" action="/admin/donate/edit">
                  <div class="modal-body">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="id" value="<%= pkg.id %>">
                    <div class="mb-2"><label class="small text-muted">Description</label><input type="text" name="desc" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= pkg.desc %>"></div>
                    <div class="mb-2"><label class="small text-muted">Cost (USD)</label><input type="number" step="0.01" name="cost" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= pkg.cost %>"></div>
                    <div class="mb-2"><label class="small text-muted">Points</label><input type="number" name="points" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= pkg.points %>"></div>
                  </div>
                  <div class="modal-footer border-secondary"><button type="submit" class="btn btn-gold">Save</button></div>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <tr><td colspan="5" class="text-center text-muted">No packages.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
