<h3 class="mb-3"><i class="fas fa-vote-yea me-2"></i>Vote Sites</h3>
<p class="text-muted mb-4" style="font-size:12px;">
  Manage vote sites. Two types available:<br>
  <span class="badge bg-info text-dark">Link</span> — Player clicks vote, opens external URL in new tab, earns points after cooldown.<br>
  <span class="badge bg-warning text-dark">Fake</span> — Instant vote button, no external site. Player clicks and earns points immediately (with cooldown).
</p>

<!-- Add Vote Site -->
<div class="card bg-dark border-secondary mb-4">
  <div class="card-header border-secondary text-gold"><i class="fas fa-plus me-1"></i> Add Vote Site</div>
  <div class="card-body">
    <form method="POST" action="/admin/vote/add">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label small text-muted">Site Name</label>
          <input type="text" name="hostname" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="e.g. TopG, Arena-Top100" required>
        </div>
        <div class="col-md-2">
          <label class="form-label small text-muted">Type</label>
          <select name="vote_type" class="form-select form-select-sm bg-dark text-light border-secondary" onchange="toggleVoteLink(this, 'add')">
            <option value="link">Link (External)</option>
            <option value="fake">Fake (Instant)</option>
          </select>
        </div>
        <div class="col-md-6" id="add-votelink-wrap">
          <label class="form-label small text-muted">Vote URL</label>
          <input type="url" name="votelink" id="add-votelink" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="https://topg.org/wow/server/...">
        </div>
      </div>
      <div class="row g-3 mb-3">
        <div class="col-md-3">
          <label class="form-label small text-muted">Image URL (optional)</label>
          <input type="url" name="image_url" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="https://...banner.png">
        </div>
        <div class="col-md-2">
          <label class="form-label small text-muted">Points Reward</label>
          <input type="number" name="points" class="form-control form-control-sm bg-dark text-light border-secondary" value="1" min="1" required>
        </div>
        <div class="col-md-2">
          <label class="form-label small text-muted">Cooldown (hours)</label>
          <input type="number" name="reset_time" class="form-control form-control-sm bg-dark text-light border-secondary" value="12" min="1" required>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <div class="form-check">
            <input type="checkbox" name="active" value="1" class="form-check-input" id="add-active" checked>
            <label class="form-check-label small text-muted" for="add-active">Active</label>
          </div>
        </div>
        <div class="col-md-3 d-flex align-items-end">
          <button type="submit" class="btn btn-gold w-100"><i class="fas fa-plus me-1"></i> Add Site</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Sites List -->
<div class="table-responsive">
  <table class="table table-dark table-hover table-sm align-middle">
    <thead>
      <tr>
        <th width="40">ID</th>
        <th>Name</th>
        <th width="80">Type</th>
        <th>Vote Link</th>
        <th width="60">Points</th>
        <th width="80">Cooldown</th>
        <th width="60">Active</th>
        <th width="100">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (sites && sites.length) { %>
        <% sites.forEach(function(s) { %>
          <tr class="<%= !s.active ? 'opacity-50' : '' %>">
            <td><%= s.id %></td>
            <td><strong><%= s.hostname %></strong></td>
            <td>
              <% if (s.vote_type === 'fake') { %>
                <span class="badge bg-warning text-dark">Fake</span>
              <% } else { %>
                <span class="badge bg-info text-dark">Link</span>
              <% } %>
            </td>
            <td class="text-truncate" style="max-width:220px;">
              <% if (s.vote_type === 'link' && s.votelink) { %>
                <a href="<%= s.votelink %>" target="_blank" class="text-info" style="font-size:12px;"><%= s.votelink %></a>
              <% } else { %>
                <span class="text-muted">—</span>
              <% } %>
            </td>
            <td class="text-warning"><b><%= s.points %></b></td>
            <td><%= s.reset_time %>h</td>
            <td>
              <% if (s.active) { %>
                <span class="badge bg-success">On</span>
              <% } else { %>
                <span class="badge bg-secondary">Off</span>
              <% } %>
            </td>
            <td>
              <button class="btn btn-sm btn-outline-gold me-1" data-bs-toggle="modal" data-bs-target="#edit-v-<%= s.id %>"><i class="fas fa-edit"></i></button>
              <form method="POST" action="/admin/vote/delete" class="d-inline" onsubmit="return confirm('Delete &quot;<%= s.hostname %>&quot;?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="id" value="<%= s.id %>">
                <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
              </form>
            </td>
          </tr>

          <!-- Edit Modal -->
          <div class="modal fade" id="edit-v-<%= s.id %>" tabindex="-1">
            <div class="modal-dialog">
              <div class="modal-content bg-dark text-light">
                <div class="modal-header border-secondary">
                  <h5 class="modal-title text-gold"><i class="fas fa-edit me-1"></i> Edit: <%= s.hostname %></h5>
                  <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form method="POST" action="/admin/vote/edit">
                  <div class="modal-body">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="id" value="<%= s.id %>">
                    <div class="mb-3">
                      <label class="form-label small text-muted">Site Name</label>
                      <input type="text" name="hostname" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= s.hostname %>" required>
                    </div>
                    <div class="mb-3">
                      <label class="form-label small text-muted">Type</label>
                      <select name="vote_type" class="form-select form-select-sm bg-dark text-light border-secondary" onchange="toggleVoteLink(this, 'edit-<%= s.id %>')">
                        <option value="link" <%= s.vote_type === 'link' ? 'selected' : '' %>>Link (External)</option>
                        <option value="fake" <%= s.vote_type === 'fake' ? 'selected' : '' %>>Fake (Instant)</option>
                      </select>
                    </div>
                    <div class="mb-3" id="edit-<%= s.id %>-votelink-wrap" style="<%= s.vote_type === 'fake' ? 'display:none' : '' %>">
                      <label class="form-label small text-muted">Vote URL</label>
                      <input type="url" name="votelink" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= s.votelink || '' %>">
                    </div>
                    <div class="mb-3">
                      <label class="form-label small text-muted">Image URL (optional)</label>
                      <input type="url" name="image_url" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= s.image_url || '' %>">
                    </div>
                    <div class="row g-3">
                      <div class="col-4">
                        <label class="form-label small text-muted">Points</label>
                        <input type="number" name="points" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= s.points %>" min="1">
                      </div>
                      <div class="col-4">
                        <label class="form-label small text-muted">Cooldown (hrs)</label>
                        <input type="number" name="reset_time" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= s.reset_time %>" min="1">
                      </div>
                      <div class="col-4 d-flex align-items-end">
                        <div class="form-check">
                          <input type="checkbox" name="active" value="1" class="form-check-input" id="edit-active-<%= s.id %>" <%= s.active ? 'checked' : '' %>>
                          <label class="form-check-label" for="edit-active-<%= s.id %>">Active</label>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-gold">Save Changes</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <tr><td colspan="8" class="text-center text-muted py-4">No vote sites configured. Add one above.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<script>
function toggleVoteLink(sel, prefix) {
  var wrap = document.getElementById(prefix + '-votelink-wrap');
  if (wrap) {
    wrap.style.display = sel.value === 'fake' ? 'none' : '';
  }
}
</script>
