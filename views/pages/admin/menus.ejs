<%
  /* Category definitions — must match Menu.MENU_META in models/Menu.js */
  var categories = {
    1: { name: 'News',      icon: 'fa-newspaper',    desc: 'Home page, news, server info links' },
    2: { name: 'Account',   icon: 'fa-user-circle',  desc: 'Login, register, account management' },
    4: { name: 'Workshop',  icon: 'fa-gamepad',      desc: 'Top kills, characters, online players, stats' },
    7: { name: 'Community', icon: 'fa-users',        desc: 'Donate, vote, shop links' },
    8: { name: 'Support',   icon: 'fa-life-ring',    desc: 'FAQ, how to play, support pages' }
  };
  var catIds = [1, 2, 4, 7, 8];

  /* Group items by category */
  var grouped = {};
  catIds.forEach(function(id) { grouped[id] = []; });
  if (items && items.length) {
    items.forEach(function(m) {
      var cid = m.menu_id;
      if (!grouped[cid]) grouped[cid] = [];
      grouped[cid].push(m);
    });
  }
%>

<style>
  .cat-card { border: 1px solid #1E1D1C; border-radius: 0; background: url('/themes/wotlk/images/light.jpg') repeat; margin-bottom: 10px; overflow: hidden; }
  .cat-card-header { background: #2E2D2B; padding: 5px 15px 5px 10px; border-top: 1px solid #4a4a4a; border-bottom: 1px solid #1E1D1C; display: flex; align-items: center; justify-content: space-between; }
  .cat-card-header h5 { margin: 0; color: #fceac6; font-family: arial, sans-serif; font-size: 10pt; font-weight: bold; }
  .cat-card-header .cat-desc { color: #a0a1a3; font-size: 11px; margin-left: 10px; font-family: Arial, Helvetica, sans-serif; }
  .cat-card-header .cat-icon { color: #fceac6; font-size: 14px; margin-right: 8px; }
  .cat-card-body { padding: 0; }
  .cat-card-body table { margin-bottom: 0; width: 100%; }
  .cat-card-body th { color: #C7C7C7; background: #2E2D2B; font-size: 10pt; font-weight: bold; font-family: arial, sans-serif; padding: 5px 10px; border-top: 1px solid #4a4a4a; border-bottom: 1px solid #1E1D1C; border-left: 1px solid #4a4a4a; border-right: 1px solid #1E1D1C; }
  .cat-card-body td { padding: 5px 10px; border-bottom: 1px solid #D8BF95; color: #333; font-size: 12px; font-family: Arial, Helvetica, sans-serif; vertical-align: middle; }
  .cat-card-body tr:nth-child(even) td { background: #C3AD89; }
  .cat-card-body tr:hover td { background: rgba(208,168,3,0.15); }
  .add-row td { padding: 8px 6px; background: transparent !important; }
  .add-row input, .add-row select { background: #f5f0e1; border: 1px solid #8e7c56; color: #333; font-size: 12px; padding: 4px 8px; border-radius: 0; width: 100%; }
  .add-row input:focus, .add-row select:focus { border-color: #d0a803; outline: none; }
  .btn-gold-sm { background: #ae813e; color: #fff; border: 1px solid #835a20; font-size: 11px; font-weight: bold; padding: 4px 12px; border-radius: 0; cursor: pointer; }
  .btn-gold-sm:hover { background: #c9963f; }
  .btn-del { background: none; border: 1px solid #c60000; color: #c60000; font-size: 11px; padding: 3px 8px; border-radius: 0; cursor: pointer; }
  .btn-del:hover { background: #c60000; color: #fff; }
  .btn-edit-sm { background: none; border: 1px solid #ae813e; color: #835a20; font-size: 11px; padding: 3px 8px; border-radius: 0; cursor: pointer; }
  .btn-edit-sm:hover { background: #ae813e; color: #fff; }
  .level-badge { font-size: 10px; padding: 2px 6px; border-radius: 0; font-weight: bold; }
  .level-all { background: #2a6a2a; color: #fff; }
  .level-user { background: #1e4378; color: #fff; }
  .level-admin { background: #8a2020; color: #fff; }
  .guest-badge { background: #ae813e; color: #fff; font-size: 10px; padding: 2px 6px; border-radius: 0; font-weight: bold; }
  .empty-cat { color: #8b8072; font-style: italic; font-size: 12px; padding: 15px; text-align: center; }
</style>

<h3 class="mb-3">
  <i class="fas fa-bars me-2"></i>Sidebar Menu Management
</h3>
<p class="text-muted mb-4" style="font-size:12px;">
  Manage the left sidebar menu links. Items are grouped by category and sorted by order within each category.
  <br>The sidebar displays 5 collapsible sections: <strong style="color:#640909;">News</strong>, <strong style="color:#640909;">Account</strong>, <strong style="color:#640909;">Workshop</strong>, <strong style="color:#640909;">Community</strong>, and <strong style="color:#640909;">Support</strong>.
</p>

<% catIds.forEach(function(catId) {
  var cat = categories[catId];
  var catItems = grouped[catId] || [];
  catItems.sort(function(a, b) { return (a.order || 0) - (b.order || 0); });
%>
<div class="cat-card">
  <div class="cat-card-header">
    <div style="display:flex; align-items:center;">
      <i class="fas <%= cat.icon %> cat-icon"></i>
      <h5>Category <%= catId %>: <%= cat.name %></h5>
      <span class="cat-desc">— <%= cat.desc %></span>
    </div>
    <span style="color:#666; font-size:11px;"><%= catItems.length %> item<%= catItems.length !== 1 ? 's' : '' %></span>
  </div>
  <div class="cat-card-body">
    <table width="100%" cellspacing="0" cellpadding="0">
      <thead>
        <tr>
          <th width="40">#</th>
          <th>Title</th>
          <th>URL</th>
          <th width="60">Order</th>
          <th width="80">Visibility</th>
          <th width="100">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (catItems.length) { %>
          <% catItems.forEach(function(m, idx) { %>
            <tr>
              <td style="color:#666;"><%= idx + 1 %></td>
              <td><strong><%= m.link_title %></strong></td>
              <td style="color:#1e4378;"><%= m.link %></td>
              <td style="text-align:center;"><%= m.order || 0 %></td>
              <td>
                <% if (m.account_level === 0) { %>
                  <span class="level-badge level-all">Everyone</span>
                <% } else if (m.account_level >= 3) { %>
                  <span class="level-badge level-admin">Admin</span>
                <% } else { %>
                  <span class="level-badge level-user">User</span>
                <% } %>
                <% if (m.guest_only) { %><span class="guest-badge ms-1">Guest</span><% } %>
              </td>
              <td>
                <button class="btn-edit-sm me-1" onclick="editItem(<%= m.id %>, <%= m.menu_id %>, '<%= m.link_title.replace(/'/g, "\\'") %>', '<%= m.link.replace(/'/g, "\\'") %>', <%= m.order || 0 %>, <%= m.account_level %>, <%= m.guest_only ? 1 : 0 %>)"><i class="fas fa-pen"></i></button>
                <form method="POST" action="/admin/menus/delete" class="d-inline" onsubmit="return confirm('Delete &quot;<%= m.link_title %>&quot;?')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="id" value="<%= m.id %>">
                  <button type="submit" class="btn-del"><i class="fas fa-trash"></i></button>
                </form>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="6" class="empty-cat">No items in this category yet. Add one below.</td></tr>
        <% } %>

        <!-- Inline add row -->
        <tr class="add-row">
          <form method="POST" action="/admin/menus/add">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="menu_id" value="<%= catId %>">
            <td style="text-align:center;color:#666;"><i class="fas fa-plus" style="color:#FFAC04;"></i></td>
            <td><input type="text" name="link_title" placeholder="Link title" required></td>
            <td><input type="text" name="link" placeholder="/path/to/page" required></td>
            <td><input type="number" name="order" placeholder="0" value="<%= catItems.length + 1 %>" style="text-align:center; width:50px;"></td>
            <td>
              <select name="account_level">
                <option value="0">Everyone</option>
                <option value="1" selected>Users</option>
                <option value="3">Admin</option>
              </select>
            </td>
            <td>
              <button type="submit" class="btn-gold-sm"><i class="fas fa-plus me-1"></i>Add</button>
            </td>
          </form>
        </tr>
      </tbody>
    </table>
  </div>
</div>
<% }); %>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-pen me-2"></i>Edit Menu Item</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/admin/menus/edit">
        <div class="modal-body">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="id" id="edit-id">
          <div class="mb-3">
            <label class="form-label">Category</label>
            <select name="menu_id" id="edit-menu_id" class="form-select form-select-sm">
              <% catIds.forEach(function(cid) { %>
                <option value="<%= cid %>"><%= cid %>. <%= categories[cid].name %></option>
              <% }); %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Title</label>
            <input type="text" name="link_title" id="edit-title" class="form-control form-control-sm" required>
          </div>
          <div class="mb-3">
            <label class="form-label">URL</label>
            <input type="text" name="link" id="edit-link" class="form-control form-control-sm" required>
          </div>
          <div class="row g-3">
            <div class="col-4">
              <label class="form-label">Order</label>
              <input type="number" name="order" id="edit-order" class="form-control form-control-sm">
            </div>
            <div class="col-4">
              <label class="form-label">Visibility</label>
              <select name="account_level" id="edit-level" class="form-select form-select-sm">
                <option value="0">Everyone</option>
                <option value="1">Users</option>
                <option value="3">Admin</option>
              </select>
            </div>
            <div class="col-4 d-flex align-items-end">
              <div class="form-check">
                <input type="checkbox" name="guest_only" value="1" class="form-check-input" id="edit-guest">
                <label class="form-check-label" for="edit-guest">Guest only</label>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-gold-sm">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function editItem(id, menuId, title, link, order, level, guest) {
  document.getElementById('edit-id').value = id;
  document.getElementById('edit-menu_id').value = menuId;
  document.getElementById('edit-title').value = title;
  document.getElementById('edit-link').value = link;
  document.getElementById('edit-order').value = order;
  document.getElementById('edit-level').value = level;
  document.getElementById('edit-guest').checked = !!guest;
  new bootstrap.Modal(document.getElementById('editModal')).show();
}
</script>
