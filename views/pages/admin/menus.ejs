<h3 class="mb-4">Menu Management</h3>

<!-- Add Menu Item -->
<div class="card bg-dark border-secondary mb-4">
  <div class="card-header text-gold">Add Menu Item</div>
  <div class="card-body">
    <form method="POST" action="/admin/menus/add">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="row g-2">
        <div class="col-md-2">
          <select name="menu_id" class="form-select form-select-sm bg-dark text-light border-secondary">
            <option value="1">Menu 1 (Sidebar)</option>
            <option value="2">Menu 2 (Footer)</option>
            <option value="3">Menu 3 (Extra)</option>
          </select>
        </div>
        <div class="col-md-2"><input type="text" name="link_title" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Title" required></div>
        <div class="col-md-3"><input type="text" name="link" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="URL" required></div>
        <div class="col-md-1"><input type="number" name="order" class="form-control form-control-sm bg-dark text-light border-secondary" placeholder="Order" value="0"></div>
        <div class="col-md-1">
          <select name="account_level" class="form-select form-select-sm bg-dark text-light border-secondary">
            <option value="0">All</option>
            <option value="1" selected>User</option>
            <option value="3">Admin</option>
          </select>
        </div>
        <div class="col-md-1">
          <div class="form-check mt-1"><input type="checkbox" name="guest_only" value="1" class="form-check-input" id="go"><label class="form-check-label small" for="go">Guest</label></div>
        </div>
        <div class="col-md-2"><button type="submit" class="btn btn-sm btn-gold w-100">Add</button></div>
      </div>
    </form>
  </div>
</div>

<!-- Menu Items Table -->
<div class="table-responsive">
  <table class="table table-dark table-hover table-sm">
    <thead><tr><th>ID</th><th>Menu</th><th>Title</th><th>URL</th><th>Order</th><th>Level</th><th>Guest</th><th>Actions</th></tr></thead>
    <tbody>
      <% if (items && items.length) { %>
        <% items.forEach(m => { %>
          <tr>
            <td><%= m.id %></td>
            <td><%= m.menu_id %></td>
            <td><%= m.link_title %></td>
            <td class="text-truncate" style="max-width:150px"><%= m.link %></td>
            <td><%= m.order || m.sort_order || 0 %></td>
            <td><%= m.account_level %></td>
            <td><%= m.guest_only ? 'Yes' : '' %></td>
            <td>
              <button class="btn btn-sm btn-outline-gold me-1" data-bs-toggle="modal" data-bs-target="#edit-m-<%= m.id %>"><i class="fas fa-edit"></i></button>
              <form method="POST" action="/admin/menus/delete" class="d-inline" onsubmit="return confirm('Delete?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="id" value="<%= m.id %>">
                <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
              </form>
            </td>
          </tr>

          <div class="modal fade" id="edit-m-<%= m.id %>" tabindex="-1">
            <div class="modal-dialog">
              <div class="modal-content bg-dark text-light">
                <div class="modal-header border-secondary"><h5 class="modal-title text-gold">Edit Menu Item</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <form method="POST" action="/admin/menus/edit">
                  <div class="modal-body">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="id" value="<%= m.id %>">
                    <div class="mb-2"><label class="small text-muted">Menu</label><select name="menu_id" class="form-select form-select-sm bg-dark text-light border-secondary"><option value="1" <%= m.menu_id==1?'selected':'' %>>1</option><option value="2" <%= m.menu_id==2?'selected':'' %>>2</option><option value="3" <%= m.menu_id==3?'selected':'' %>>3</option></select></div>
                    <div class="mb-2"><label class="small text-muted">Title</label><input type="text" name="link_title" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= m.link_title %>"></div>
                    <div class="mb-2"><label class="small text-muted">URL</label><input type="text" name="link" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= m.link %>"></div>
                    <div class="mb-2"><label class="small text-muted">Order</label><input type="number" name="order" class="form-control form-control-sm bg-dark text-light border-secondary" value="<%= m.order || m.sort_order || 0 %>"></div>
                    <div class="mb-2"><label class="small text-muted">Min Level</label><select name="account_level" class="form-select form-select-sm bg-dark text-light border-secondary"><option value="0" <%= m.account_level==0?'selected':'' %>>All</option><option value="1" <%= m.account_level==1?'selected':'' %>>User</option><option value="3" <%= m.account_level==3?'selected':'' %>>Admin</option></select></div>
                    <div class="form-check"><input type="checkbox" name="guest_only" value="1" class="form-check-input" <%= m.guest_only?'checked':'' %>><label class="form-check-label small">Guest Only</label></div>
                  </div>
                  <div class="modal-footer border-secondary"><button type="submit" class="btn btn-gold">Save</button></div>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <tr><td colspan="8" class="text-center text-muted">No menu items.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
