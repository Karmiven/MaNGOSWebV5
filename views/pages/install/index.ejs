<%
  var tp = typeof themePath !== 'undefined' ? themePath : '/themes/wotlk';
%>
<style type="text/css">
  td.installRow1 { font-size: 0.85em; border-style: solid; border-width: 0px 1px 1px 0px; border-color: #D8BF95; padding: 6px 8px; }
  td.installRow2 { font-size: 0.85em; border-style: solid; border-width: 0px 1px 1px 0px; border-color: #D8BF95; background-color: #C3AD89; padding: 6px 8px; }
  td.rankingHeader { color: #C7C7C7; font-size: 10pt; font-family: arial,helvetica,sans-serif; font-weight: bold; background-color: #2E2D2B; border-style: solid; border-width: 1px; border-color: #5D5D5D #5D5D5D #1E1D1C #1E1D1C; padding: 3px; }
  .install-input {
    font-family: Verdana, Arial, sans-serif; font-size: 11px;
    border: 1px solid #928058; background-color: #f5ecd7; color: #333;
    padding: 3px 6px; width: 100%; box-sizing: border-box;
  }
  .install-input:focus { border-color: #5a4a2a; background-color: #fff; outline: none; }
  .install-btn {
    font-family: Verdana, Arial, sans-serif; font-size: 11px; font-weight: bold;
    background: #2E2D2B; color: #C7C7C7; border: 1px solid #5D5D5D;
    padding: 4px 16px; cursor: pointer;
  }
  .install-btn:hover { background: #3E3D3B; color: #fff; }
  .install-btn-gold {
    font-family: Verdana, Arial, sans-serif; font-size: 11px; font-weight: bold;
    background: linear-gradient(to bottom, #d4a817, #a07c0c); color: #fff; border: 1px solid #8a6d0a;
    padding: 5px 20px; cursor: pointer; text-shadow: 1px 1px 1px rgba(0,0,0,0.5);
  }
  .install-btn-gold:hover { background: linear-gradient(to bottom, #e4b827, #b08c1c); }
  .install-btn-test {
    font-family: Verdana, Arial, sans-serif; font-size: 10px; font-weight: bold;
    background: #05374a; color: #fff; border: 1px solid #03273a; padding: 3px 10px; cursor: pointer;
  }
  .install-btn-test:hover { background: #075a7a; }
  .step-box { display: inline-block; width: 28px; height: 28px; line-height: 28px; text-align: center; font-weight: bold; font-size: 12px; margin: 0 3px; border: 1px solid #5D5D5D; }
  .step-pending { background: #2E2D2B; color: #8b949e; }
  .step-active { background: linear-gradient(to bottom, #d4a817, #a07c0c); color: #fff; border-color: #8a6d0a; }
  .step-done { background: #234303; color: #fff; border-color: #1a3202; }
  .test-result { font-size: 10px; font-family: Verdana, Arial, sans-serif; }
  .text-ok { color: #234303; }
  .text-fail { color: #640909; }
  .text-wait { color: #1e4378; }
  .install-progress-bar {
    height: 8px; background: #2E2D2B; border: 1px solid #5D5D5D; margin: 8px 0;
  }
  .install-progress-fill {
    height: 100%; background: linear-gradient(to right, #d4a817, #a07c0c); width: 0%; transition: width 0.5s;
  }
  .install-alert {
    padding: 8px 12px; margin: 8px 0; font-size: 12px; font-family: Verdana, Arial, sans-serif;
  }
  .install-alert-success { background: #d4edda; border: 1px solid #234303; color: #234303; }
  .install-alert-error { background: #f8d7da; border: 1px solid #640909; color: #640909; }
  .step-panel { display: none; }
  .step-panel.active { display: block; }
</style>

