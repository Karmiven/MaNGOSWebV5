<script type="text/javascript">
  var currentStep = 1;

  function clearValidation() {
    var els = document.querySelectorAll('.install-input');
    for (var i = 0; i < els.length; i++) { els[i].style.borderColor = '#928058'; els[i].style.backgroundColor = '#f5ecd7'; }
    var alertEl = document.getElementById('alert-box');
    alertEl.style.display = 'none';
  }

  function validateStep2() {
    var prefixes = ['cms', 'auth', 'char', 'world'];
    var fields = ['host', 'port', 'db', 'user', 'pass'];
    var missing = [];
    for (var p = 0; p < prefixes.length; p++) {
      for (var f = 0; f < fields.length; f++) {
        var el = document.getElementById(prefixes[p] + '_' + fields[f]);
        if (!el.value.trim()) {
          el.style.borderColor = '#cc0000';
          el.style.backgroundColor = '#f8d7da';
          missing.push(prefixes[p].toUpperCase() + ' ' + fields[f]);
        } else {
          el.style.borderColor = '#928058';
          el.style.backgroundColor = '#f5ecd7';
        }
      }
    }
    if (missing.length > 0) {
      showAlert('error', 'Please fill in all required database fields (highlighted in red).');
      return false;
    }
    return true;
  }

  function validateStep3() {
    var user = document.getElementById('admin_user');
    var pass = document.getElementById('admin_pass');
    var missing = [];
    if (!user.value.trim()) { user.style.borderColor = '#cc0000'; user.style.backgroundColor = '#f8d7da'; missing.push('Username'); }
    else { user.style.borderColor = '#928058'; user.style.backgroundColor = '#f5ecd7'; }
    if (!pass.value.trim()) { pass.style.borderColor = '#cc0000'; pass.style.backgroundColor = '#f8d7da'; missing.push('Password'); }
    else { pass.style.borderColor = '#928058'; pass.style.backgroundColor = '#f5ecd7'; }
    if (missing.length > 0) {
      showAlert('error', 'Admin ' + missing.join(' and ') + ' required.');
      return false;
    }
    return true;
  }

  function switchToStep(n) {
    var panels = document.querySelectorAll('.step-panel');
    for (var i = 0; i < panels.length; i++) { panels[i].className = 'step-panel'; }
    document.getElementById('step-' + n).className = 'step-panel active';
    for (var i = 1; i <= 4; i++) {
      var el = document.getElementById('si-' + i);
      el.className = 'step-box';
      if (i < n) el.className += ' step-done';
      else if (i === n) el.className += ' step-active';
      else el.className += ' step-pending';
    }
    currentStep = n;
    window.scrollTo(0, 0);
  }

  function testAllDbs(callback) {
    var dbPrefixes = ['cms', 'auth', 'char', 'world'];
    var tested = 0;
    var errors = [];
    for (var d = 0; d < dbPrefixes.length; d++) {
      (function(prefix) {
        var testData = {
          host: document.getElementById(prefix + '_host').value,
          port: document.getElementById(prefix + '_port').value,
          user: document.getElementById(prefix + '_user').value,
          password: document.getElementById(prefix + '_pass').value,
          database: document.getElementById(prefix + '_db').value
        };
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/install/test-db', true);
        xhr.setRequestHeader('Content-Type', 'application/json');
        xhr.onload = function() {
          tested++;
          if (xhr.status === 200) {
            var result = JSON.parse(xhr.responseText);
            if (!result.success) errors.push(prefix.toUpperCase() + ': ' + result.message);
          } else {
            errors.push(prefix.toUpperCase() + ': request failed');
          }
          if (tested === 4) callback(errors);
        };
        xhr.onerror = function() {
          tested++;
          errors.push(prefix.toUpperCase() + ': connection error');
          if (tested === 4) callback(errors);
        };
        xhr.send(JSON.stringify(testData));
      })(dbPrefixes[d]);
    }
  }

  function goStep(n) {
    clearValidation();
    // Going backward — always allow
    if (n <= currentStep) { switchToStep(n); return; }
    // Validate Step 2 fields
    if (currentStep === 2) {
      if (!validateStep2()) return;
      // Test all DB connections before allowing next
      showAlert('success', 'Testing database connections...');
      testAllDbs(function(errors) {
        if (errors.length > 0) {
          showAlert('error', 'Database connection failed:<br>' + errors.join('<br>'));
        } else {
          clearValidation();
          switchToStep(n);
        }
      });
      return;
    }
    // Validate Step 3
    if (currentStep === 3 && !validateStep3()) return;
    switchToStep(n);
  }

  function testAllAndShow() {
    if (!validateStep2()) return;
    var el = document.getElementById('db-test-result');
    var btn = document.getElementById('btn-test-all');
    el.style.display = 'block';
    el.innerHTML = '<span class="text-wait">Testing all connections...</span>';
    btn.disabled = true;
    testAllDbs(function(errors) {
      btn.disabled = false;
      if (errors.length > 0) {
        el.innerHTML = '<span class="text-fail"><b>Failed:</b><br>' + errors.join('<br>') + '</span>';
      } else {
        el.innerHTML = '<span class="text-ok"><b>All 4 databases connected successfully!</b></span>';
      }
    });
  }

  function runInstall() {
    clearValidation();
    if (!validateStep2()) { switchToStep(2); return; }
    if (!validateStep3()) { switchToStep(3); return; }

    var btn = document.getElementById('btn-install');
    var progress = document.getElementById('install-progress');
    var status = document.getElementById('install-status');
    var bar = document.getElementById('progress-fill');

    btn.disabled = true;
    btn.textContent = 'Checking connections...';
    document.getElementById('btn-back-4').disabled = true;
    progress.style.display = 'block';
    bar.style.width = '10%';
    status.textContent = 'Verifying database connections...';

    testAllDbs(function(errors) {
      if (errors.length > 0) {
        showAlert('error', 'Database connection failed:<br>' + errors.join('<br>'));
        btn.disabled = false;
        btn.textContent = 'Install Now \u00BB';
        document.getElementById('btn-back-4').disabled = false;
        progress.style.display = 'none';
        bar.style.width = '0%';
        return;
      }
      bar.style.width = '30%';
      status.textContent = 'Connections OK. Running installation...';

    var fields = ['cms_host','cms_port','cms_user','cms_pass','cms_db',
      'auth_host','auth_port','auth_user','auth_pass','auth_db',
      'char_host','char_port','char_user','char_pass','char_db',
      'world_host','world_port','world_user','world_pass','world_db',
      'site_title','admin_user','admin_pass','admin_email',
      'soap_host','soap_port','soap_user','soap_pass'];
    var data = {};
    for (var i = 0; i < fields.length; i++) {
      data[fields[i]] = document.getElementById(fields[i]).value;
    }

    bar.style.width = '50%';
    status.textContent = 'Running installation...';

    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/install/run', true);
    xhr.setRequestHeader('Content-Type', 'application/json');
    xhr.onload = function() {
      bar.style.width = '100%';
      if (xhr.status === 200) {
        var result = JSON.parse(xhr.responseText);
        if (result.success) {
          status.textContent = result.message;
          showAlert('success', result.message + ' <a href="/">Go to Homepage</a>');
          btn.textContent = 'Done!';
        } else {
          onError(result.message);
        }
      } else {
        onError('Server returned status ' + xhr.status);
      }
    };
    xhr.onerror = function() {
      bar.style.width = '100%';
      onError('Connection error');
    };
    xhr.send(JSON.stringify(data));

    function onError(msg) {
      bar.style.background = '#640909';
      status.textContent = 'Error: ' + msg;
      status.style.color = '#640909';
      showAlert('error', 'Installation failed: ' + msg);
      btn.disabled = false;
      btn.textContent = 'Retry';
      document.getElementById('btn-back-4').disabled = false;
    }
    }); // end testAllDbs callback
  } // end runInstall

  function showAlert(type, msg) {
    var el = document.getElementById('alert-box');
    el.style.display = 'block';
    el.className = 'install-alert install-alert-' + type;
    el.innerHTML = msg;
  }

  goStep(1);
</script>
