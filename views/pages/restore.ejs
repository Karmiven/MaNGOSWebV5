
<div class="row justify-content-center">
  <div class="col-md-5 col-lg-4">
    <div class="card wow-card">
      <div class="card-header text-center">
        <h4 class="font-cinzel text-gold mb-0"><i class="fas fa-key me-2"></i>Restore Password</h4>
      </div>
      <div class="card-body">
        <p class="text-muted small">Enter your username and registered email to receive a new password.</p>
        <form method="POST" action="/auth/restore">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label">Username</label>
            <input type="text" name="username" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-gold w-100"><i class="fas fa-paper-plane me-2"></i>Reset Password</button>
        </form>
      </div>
      <div class="card-footer text-center small">
        <a href="/auth/login" class="text-gold">Back to Login</a>
      </div>
    </div>
  </div>
</div>
