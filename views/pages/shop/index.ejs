
<!-- Item Shop — V4 Blizzlike Style -->
<div class="subheader-bar">
  <div class="sh-left"></div>
  <div class="sh-mid"><b>Item Shop</b></div>
  <div class="sh-right"></div>
</div>

<% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
  <div style="margin-bottom:10px;">
    <a href="/shop" class="btn-blizz" style="margin-right:3px;">All</a>
    <% categories.forEach(function(cat) { %>
      <a href="/shop?category=<%= encodeURIComponent(cat) %>" class="btn-blizz" style="margin-right:3px;"><%= cat %></a>
    <% }); %>
  </div>
<% } %>

<% if (typeof user !== 'undefined' && user) { %>
  <div class="flash-message flash-info">Your balance: <b><%= user.web_points || 0 %> Points</b></div>
<% } %>

<% if (typeof items !== 'undefined' && items && items.length > 0) { %>
  <table class="blizz-table">
    <tr>
      <th>Item</th>
      <th>Description</th>
      <th>Price</th>
      <th style="width:200px;">Action</th>
    </tr>
    <% items.forEach(function(item) { %>
      <tr>
        <td><b><%= item.name %></b><% if (item.item_id) { %> <small style="color:#999;">(ID: <%= item.item_id %> x<%= item.item_count || 1 %>)</small><% } %></td>
        <td><%= item.description || 'No description' %></td>
        <td style="color:#1e4378; font-weight:bold;"><%= item.price %> pts</td>
        <td>
          <% if (typeof user !== 'undefined' && user) { %>
            <form method="POST" action="/shop/buy" style="display:inline;" onsubmit="return confirm('Buy <%= item.name %> for <%= item.price %> points?');">
              <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <input type="hidden" name="itemId" value="<%= item.id %>">
              <% if (typeof characters !== 'undefined' && characters && characters.length > 0) { %>
                <select name="characterName" required style="font-size:10px; border:1px solid #8e7c56; padding:2px;">
                  <option value="">Character...</option>
                  <% characters.forEach(function(ch) { %>
                    <option value="<%= ch.name %>"><%= ch.name %></option>
                  <% }); %>
                </select>
              <% } %>
              <input type="submit" value="Buy" class="btn-blizz" style="padding:2px 10px;" <%= (typeof characters === 'undefined' || !characters || characters.length === 0) ? 'disabled' : '' %>>
            </form>
          <% } else { %>
            <a href="/auth/login" class="btn-blizz" style="padding:2px 10px;">Login to Buy</a>
          <% } %>
        </td>
      </tr>
    <% }); %>
  </table>
<% } else { %>
  <p style="padding:10px; color:#333;">No items available in the shop.</p>
<% } %>
