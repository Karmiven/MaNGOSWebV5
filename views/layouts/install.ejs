                                                            <div style="clear:both;display:block;position:relative;width:100%;margin-top:-4px;">
                                                            <!-- Pathway -->
                                                            <div class="redbannerbg"><div class="redbannerleft"></div><div class="redbannerlabel">Installation Wizard</div><div class="redbannerright"></div></div>
                                                            <!-- Component body BEGIN -->
                                                            <br>
                                                            <%- body %>
                                                            <!-- Component body END -->
                                                            </div>
                                                            </div>
                                                          </div>
                                                        </div>
                                                      </div>
                                                      <div id="cnt-bot">
                                                        <div>
                                                          <div>&nbsp;</div>
                                                        </div>
                                                      </div>
                                                    </div>
