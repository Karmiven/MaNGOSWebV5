<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
<meta http-equiv="content-type" content="text/html; charset=UTF-8"/>
<%
  var tp = typeof themePath !== 'undefined' ? themePath : '/themes/wotlk';
  var isFrontpage = (typeof currentUrl !== 'undefined' && (currentUrl === '/' || currentUrl.startsWith('/?')));
  var siteTitle = (typeof siteConfig !== 'undefined' && siteConfig.site_title) ? siteConfig.site_title : 'MaNGOSWebV5';
%>
<link rel="shortcut icon" href="<%= tp %>/images/favicon.ico"/>
<title><%= siteTitle %><%= typeof title !== 'undefined' ? ' \u00BB ' + title : '' %></title>
<style media="screen" title="currentStyle" type="text/css">
    @import url("<%= tp %>/css/newhp.css");
    @import url("<%= tp %>/css/newhp_basic.css");
    @import url("<%= tp %>/css/newhp_icons.css");
    @import url("<%= tp %>/css/newhp_layout.css");
    @import url("<%= tp %>/css/newhp_specific.css");
    @import url("<%= tp %>/css/additional_optimisation.css");
</style>
<% if (isFrontpage) { %>
<link rel="stylesheet" href="<%= tp %>/css/additional_fp.css"/>
<% } %>
<link rel="stylesheet" href="/css/v5-override.css"/>
<link rel="stylesheet" href="<%= tp %>/css/theme-override.css"/>
<script type="text/javascript"><!--
    var SITE_HREF = '/';
    var DOMAIN_PATH = '/';
    var SITE_PATH = '/';
--></script>
<script src="<%= tp %>/js/detection.js" type="text/javascript"></script>
<script src="<%= tp %>/js/functions.js" type="text/javascript"></script>
</head>
<body>
<!-- Top Navbar Start -->
<style>@import "<%= tp %>/css/topnav.css";</style>
<div id="shared_topnav" class="tn_wow">
  <div class="topnav">
    <div class="tn_interior">
      <a href="/">Home</a>
      <a href="/server">Server</a>
      <% if (typeof siteConfig === 'undefined' || !siteConfig || siteConfig.module_online_list != '0') { %><a href="/server/online">Players</a><% } %>
      <a href="/server/topkills">Top Kills</a>
      <a href="/shop">Shop</a>
      <% if (typeof siteConfig === 'undefined' || !siteConfig || siteConfig.module_voting != '0') { %><a href="/vote">Vote</a><% } %>
      <a href="/donate">Donate</a>
      <a href="/support">Support</a>
    </div>
  </div>
  <div class="tn_push"></div>
</div>

<!-- TOOLTIP start -->
<div id="contents">
<table cellspacing="0" cellpadding="0" border="0" width="100%">
<tr>
  <td><img src="<%= tp %>/images/pixel.gif" width="1" height="1" alt="" /></td>
  <td bgcolor="#000000"></td>
  <td><img src="<%= tp %>/images/pixel.gif" width="1" height="1" alt="" /></td>
</tr>
<tr>
  <td bgcolor="#000000"></td>
  <td>
      <table cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
        <td width="1" height="1" bgcolor="#000000"></td>
        <td bgcolor="#D5D5D7" height="1"><img src="<%= tp %>/images/pixel.gif" width="1" height="1" alt="" /></td>
        <td width="1" height="1" bgcolor="#000000"></td>
        </tr>
        <tr>
        <td bgcolor="#A5A5A5" width="1"><img src="<%= tp %>/images/pixel.gif" width="1" height="1" alt="" /></td>
        <td valign="top" class="trans_div"><div id="tooltiptext"></div></td>
        <td bgcolor="#A5A5A5" width="1"><img src="<%= tp %>/images/pixel.gif" width="1" height="1" alt="" /></td>
        </tr>
        <tr>
        <td width="1" height="1" bgcolor="#000000"></td>
        <td bgcolor="#4F4F4F"><img src="<%= tp %>/images/pixel.gif" width="1" height="2" alt="" /></td>
        <td width="1" height="1" bgcolor="#000000"></td>
        </tr>
      </table>
  </td>
  <td bgcolor="#000000"></td>
</tr>
<tr>
  <td><img src="<%= tp %>/images/pixel.gif" width="1" height="1" alt="" /></td>
  <td bgcolor="#000000"></td>
  <td><img src="<%= tp %>/images/pixel.gif" width="1" height="1" alt="" /></td>
</tr>
</table>
</div>
<script src="<%= tp %>/js/tooltip.js" type="text/javascript"></script>
<!-- TOOLTIP end -->

    <div style="background: url(<%= tp %>/images/page-bg-top.jpg) repeat-x 0 0; height: 88px; position: relative; width: 100%; "></div>
    <center>
      <table align="center" border="0" cellpadding="0" cellspacing="0">
        <tr>
          <td>
            <div id="hp">
              <div class="top-nav-container">
                <!-- Login Box -->
                <div id="loginbox">
                  <div class="loginboxleft"></div>
                  <div class="loginboxbg">
                    <% if (typeof user !== 'undefined' && user) { %>
                      <span style="color:#FFAC04; font-size:11px;">
                        <%= user.username %>
                        <a href="/account/manage"><img src="<%= tp %>/images/button-profile.gif" alt="Profile"/></a>
                        <a href="/auth/logout"><img src="<%= tp %>/images/button-logout.gif" alt="Logout"/></a>
                      </span>
                    <% } else { %>
                      <form action="/auth/login" method="post" style="margin:0; display:inline;">
                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>"/>
                        Login: <input name="username" size="14" type="text"/>
                        Password: <input name="password" size="14" type="password"/>
                        <input type="image" src="<%= tp %>/images/button-login.gif" value="Login"/>
                      </form>
                    <% } %>
                  </div>
                  <div class="loginboxright"></div>
                </div>

                <!-- Logo -->
                <div style="position: absolute; top: 0; left: 0; z-index: 20002;">
                  <div id="wow-logo">
                    <a href="/"><img title="World of Warcraft" alt="wowlogo" height="103" width="252" src="<%= tp %>/images/pixel000.gif"/></a>
                  </div>
                </div>
              </div>
              <div>
                <div id="hpwrapper">
                  <table width="100%" border="0" cellpadding="0" cellspacing="0">
                    <tr>
                      <td valign="top">
                        <div id="navwrapper">
                          <div id="nav">
                            <div id="left-bg"></div>
                            <div id="leftmenu">
                              <div id="leftmenucontainer">
                                <%- include('../partials/leftmenu') %>
                              </div>
                            </div>
                          </div>
                          <div style="clear: both;"></div>
                        </div>
                      </td><td valign="top">
                        <div id="mainwrapper">
                        <div id="main">
                            <div id="main-content-wrapper">
                              <div id="main-content">
                                <table cellspacing="0" cellpadding="0" border="0">
                                  <tr>
                                    <td>
                                      <div id="main-top">
                                        <div>
                                          <div><div></div></div>
                                        </div>
                                      </div>
                                    </td>
                                  </tr>
                                  <tr>
                                    <td>
                                      <div id="contentpadding">
                                        <div id="cnt">
                                          <div id="cnt-wrapper">
                                            <div id="contentcontainer">
                                              <table cellspacing="0" cellpadding="0" border="0" width="99%">
                                                <tr>
                                                  <td valign="top">
                                                    <div id="cntmain">
                                                      <div id="cnt-top">
                                                        <div>
                                                          <div></div>
                                                        </div>
                                                      </div>
                                                      <div id="content">
                                                        <div id="content-left">
                                                          <div id="content-right">
                                                            <div style="padding-right:-15px; margin:-15px;" id="compcont">
                                                            <div style="clear:both;display:block;position:relative;width:100%;margin-top:-4px;">
                                                            <!-- Pathway -->
                                                            <% if (!isFrontpage) { %>
                                                            <div class="redbannerbg"><div class="redbannerleft"></div><div class="redbannerlabel"><a href="/">Home</a> &raquo; <%= typeof title !== 'undefined' ? title : 'Page' %></div><div class="redbannerright"></div></div>
                                                            <% } %>
                                                            <!-- Flash messages -->
                                                            <% if (typeof flash_success !== 'undefined' && flash_success.length) { %>
                                                              <% flash_success.forEach(function(msg) { %>
                                                                <div class="flash-message flash-success"><%= msg %></div>
                                                              <% }); %>
                                                            <% } %>
                                                            <% if (typeof flash_error !== 'undefined' && flash_error.length) { %>
                                                              <% flash_error.forEach(function(msg) { %>
                                                                <div class="flash-message flash-error"><%= msg %></div>
                                                              <% }); %>
                                                            <% } %>
                                                            <!-- Site Notice -->
                                                            <% if (typeof siteConfig !== 'undefined' && siteConfig && siteConfig.site_notice_enable == '1' && siteConfig.site_notice_text) { %>
                                                              <div style="background:#fff3cd; border:1px solid #c5a96a; padding:8px 12px; margin:5px 0 10px 0; font-size:12px; color:#664d03;">
                                                                <b>Notice:</b> <%= siteConfig.site_notice_text %>
                                                              </div>
                                                            <% } %>
                                                            <!-- Component body BEGIN -->
                                                            <% if (!isFrontpage) { %>
                                                            <br>
                                                            <%- include('../partials/builddiv_start', { type: (typeof builddivType !== 'undefined' ? builddivType : 0), title: (typeof title !== 'undefined' ? title : '') }) %>
                                                            <% } %>

                                                            <%- body %>

                                                            <% if (!isFrontpage) { %>
                                                            <%- include('../partials/builddiv_end') %>
                                                            <% } %>
                                                            <!-- Component body END -->
                                                            </div>
                                                            </div>
                                                          </div>
                                                        </div>
                                                      </div>
                                                      <div id="cnt-bot">
                                                        <div>
                                                          <div>&nbsp;</div>
                                                        </div>
                                                      </div>
                                                    </div>
                                                  </td>
<% if (isFrontpage) { %>
                                                  <td valign="top" style="padding-left: 21px;padding-top: 5px;">
                                                    <%- include('../partials/rightsidebar') %>
                                                  </td>
<% } %>
                                                </tr>
                                              </table>
                                            </div>
                                          </div>
                                        </div>
                                        <div style="clear: both; font-size: 1px;">&nbsp;</div>
                                        <center>
                                          <div id="copyright">
                                            <div id="blizzlogo-bot">
                                              <img alt="Blizzard.com" border="0" src="<%= tp %>/images/bot-blizzlogo.gif"
                                                   onerror="this.style.display='none';"/>
                                            </div>
                                            <span class="textlinks">
                                            <small>
                                              &copy; <%= new Date().getFullYear() %>
                                              <b><%= siteTitle %></b> |
                                              Powered by MaNGOSWebV5 | AzerothCore 3.3.5a
                                            </small></span><br/><br/><br/>
                                          </div>
                                        </center>
                                      </div>
                                    </td>
                                  </tr>
                                  <tr>
                                    <td>
                                      <div id="main-bottom">
                                        <div>
                                          <div>
                                          </div>
                                        </div>
                                      </div>
                                    </td>
                                  </tr>
                                </table>
                              </div>
                            </div>
                            <div style="position: relative; z-index: 10;">
                              <img style="position: absolute; top: -445px; left: -243px;" alt="statue" src="<%= tp %>/images/statue.png"
                                   onerror="this.style.display='none';"/></div>
                          </div>
                        </div>
                      </td>
                    </tr>
                  </table>
                </div>
              </div>
            </div>
          </td>
        </tr>
      </table>
    </center>
    <div id="ironframe" style="z-index: 11;"></div>
    <div id="pageend"></div>
    <script src="/js/app.js" type="text/javascript"></script>
    <%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
