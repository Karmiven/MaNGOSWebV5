<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
  <meta http-equiv="content-type" content="text/html; charset=UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%
    var tp = typeof themePath !== 'undefined' ? themePath : '/themes/wotlk';
    var siteTitle = (typeof siteConfig !== 'undefined' && siteConfig.site_title) ? siteConfig.site_title : 'MaNGOSWebV5';
    var currentPath = typeof currentUrl !== 'undefined' ? currentUrl.split('?')[0] : '/admin';
  %>
  <link rel="shortcut icon" href="<%= tp %>/images/favicon.ico"/>
  <title><%= typeof title !== 'undefined' ? title : 'Admin' %> | Admin Panel</title>
  <style media="screen" title="currentStyle" type="text/css">
    @import url("<%= tp %>/css/newhp.css");
    @import url("<%= tp %>/css/newhp_basic.css");
    @import url("<%= tp %>/css/newhp_icons.css");
    @import url("<%= tp %>/css/newhp_layout.css");
    @import url("<%= tp %>/css/newhp_specific.css");
    @import url("<%= tp %>/css/additional_optimisation.css");
    @import url("<%= tp %>/css/topnav.css");
  </style>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link href="/css/v5-override.css" rel="stylesheet">
  <link href="<%= tp %>/css/theme-override.css" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
  <script type="text/javascript"><!--
    var SITE_HREF = '/';
    var DOMAIN_PATH = '/';
    var SITE_PATH = '/';
  --></script>
  <script src="<%= tp %>/js/detection.js" type="text/javascript"></script>
  <script src="<%= tp %>/js/functions.js" type="text/javascript"></script>
</head>
<body>

<!-- ===== WoW Top Navigation — Admin Quick Links ===== -->
<div id="shared_topnav" class="tn_wow">
  <div class="topnav">
    <div class="tn_interior">
      <a href="/admin">Dashboard</a>
      <a href="/admin/users">Users</a>
      <a href="/admin/news">News</a>
      <a href="/admin/shop">Shop</a>
      <a href="/admin/siteconfig">Config</a>
      <a href="/admin/banlist">Bans</a>
      <a href="/" style="color:#aaa;">Back to Site</a>
    </div>
  </div>
  <div class="tn_push"></div>
</div>

<!-- ===== Page Background Top ===== -->
<div style="background: url(<%= tp %>/images/page-bg-top.jpg) repeat-x 0 0; height: 88px; position: relative; width: 100%;"></div>

<center>
<table align="center" border="0" cellpadding="0" cellspacing="0">
<tr><td>
<div id="hp">
  <div class="top-nav-container">
    <!-- Login Box / Admin Info -->
    <div id="loginbox">
      <div class="loginboxleft"></div>
      <div class="loginboxbg">
        <span style="color:#FFAC04; font-size:11px;">
          <i class="fas fa-crown" style="font-size:10px;"></i>
          Admin: <%= typeof user !== 'undefined' && user ? user.username : 'Admin' %>
          <a href="/account/manage"><img src="<%= tp %>/images/button-profile.gif" alt="Profile"/></a>
          <a href="/auth/logout"><img src="<%= tp %>/images/button-logout.gif" alt="Logout"/></a>
        </span>
      </div>
      <div class="loginboxright"></div>
    </div>

    <!-- Logo -->
    <div style="position: absolute; top: 0; left: 0; z-index: 20002;">
      <div id="wow-logo">
        <a href="/"><img title="<%= siteTitle %>" alt="logo" height="103" width="252" src="<%= tp %>/images/pixel000.gif"/></a>
      </div>
    </div>
  </div>

  <div>
  <div id="hpwrapper">
  <table width="100%" border="0" cellpadding="0" cellspacing="0">
  <tr>
    <!-- ===== Left Sidebar — V4 Authentic Menu ===== -->
    <td valign="top">
      <div id="navwrapper">
        <div id="nav">
          <div id="left-bg"></div>
          <div id="leftmenu">
            <div id="leftmenucontainer">

              <!-- ===== Menu: Administration ===== -->
              <div id="menunews">
                <div onclick="javascript:toggleNewMenu(0);" class="menu-button-on" id="menunews-button">
                  <span class="menunews-icon-on" id="menunews-icon">&nbsp;</span>
                  <a class="menunews-header-on" id="menunews-header"><em>Menu item</em></a>
                  <a id="menunews-collapse" class="leftmenu-minuslink"></a>
                  <span class="menuentry-rightborder"></span>
                </div>
                <div id="menunews-inner">
                  <div class="leftmenu-cont-top"></div>
                  <div class="leftmenu-cont-mid">
                    <div class="m-left"><div class="m-right">
                      <div class="leftmenu-cnt">
                        <ul class="mainnav"><li style="position:relative;">
                          <div><a class="menufiller<%= currentPath === '/admin' ? ' admin-link-active' : '' %>" href="/admin">Dashboard</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/users') ? ' admin-link-active' : '' %>" href="/admin/users">Users</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/news') ? ' admin-link-active' : '' %>" href="/admin/news">News</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/chartools') ? ' admin-link-active' : '' %>" href="/admin/chartools">Characters</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/banlist') ? ' admin-link-active' : '' %>" href="/admin/banlist">Ban List</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/gamemail') ? ' admin-link-active' : '' %>" href="/admin/gamemail">Game Mail</a></div>
                        </li></ul>
                      </div>
                    </div></div>
                  </div>
                  <div class="leftmenu-cont-bot"></div>
                </div>
              </div>

              <!-- ===== Menu: Content ===== -->
              <div id="menuaccount">
                <div onclick="javascript:toggleNewMenu(1);" class="menu-button-on" id="menuaccount-button">
                  <span class="menuaccount-icon-on" id="menuaccount-icon">&nbsp;</span>
                  <a class="menuaccount-header-on" id="menuaccount-header"><em>Menu item</em></a>
                  <a id="menuaccount-collapse" class="leftmenu-minuslink"></a>
                  <span class="menuentry-rightborder"></span>
                </div>
                <div id="menuaccount-inner">
                  <div class="leftmenu-cont-top"></div>
                  <div class="leftmenu-cont-mid">
                    <div class="m-left"><div class="m-right">
                      <div class="leftmenu-cnt">
                        <ul class="mainnav"><li style="position:relative;">
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/shop') ? ' admin-link-active' : '' %>" href="/admin/shop">Shop</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/donate') ? ' admin-link-active' : '' %>" href="/admin/donate">Donate</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/vote') ? ' admin-link-active' : '' %>" href="/admin/vote">Vote Sites</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/faq') ? ' admin-link-active' : '' %>" href="/admin/faq">FAQ</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/menus') ? ' admin-link-active' : '' %>" href="/admin/menus">Menus</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/regkeys') ? ' admin-link-active' : '' %>" href="/admin/regkeys">Reg Keys</a></div>
                        </li></ul>
                      </div>
                    </div></div>
                  </div>
                  <div class="leftmenu-cont-bot"></div>
                </div>
              </div>

              <!-- ===== Menu: Settings ===== -->
              <div id="menugameguide">
                <div onclick="javascript:toggleNewMenu(2);" class="menu-button-on" id="menugameguide-button">
                  <span class="menugameguide-icon-on" id="menugameguide-icon">&nbsp;</span>
                  <a class="menugameguide-header-on" id="menugameguide-header"><em>Menu item</em></a>
                  <a id="menugameguide-collapse" class="leftmenu-minuslink"></a>
                  <span class="menuentry-rightborder"></span>
                </div>
                <div id="menugameguide-inner">
                  <div class="leftmenu-cont-top"></div>
                  <div class="leftmenu-cont-mid">
                    <div class="m-left"><div class="m-right">
                      <div class="leftmenu-cnt">
                        <ul class="mainnav"><li style="position:relative;">
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/siteconfig') ? ' admin-link-active' : '' %>" href="/admin/siteconfig">Site Config</a></div>
                          <% if (typeof user !== 'undefined' && user && user.isSuperAdmin) { %>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/realms') ? ' admin-link-active' : '' %>" href="/admin/realms">Realms</a></div>
                          <% } %>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/errorlog') ? ' admin-link-active' : '' %>" href="/admin/errorlog">Error Log</a></div>
                          <div><a class="menufiller<%= currentPath.startsWith('/admin/info') ? ' admin-link-active' : '' %>" href="/admin/info">System Info</a></div>
                        </li></ul>
                      </div>
                    </div></div>
                  </div>
                  <div class="leftmenu-cont-bot"></div>
                </div>
              </div>

              <!-- ===== Menu: Navigate ===== -->
              <div id="menuinteractive">
                <div onclick="javascript:toggleNewMenu(3);" class="menu-button-on" id="menuinteractive-button">
                  <span class="menuinteractive-icon-on" id="menuinteractive-icon">&nbsp;</span>
                  <a class="menuinteractive-header-on" id="menuinteractive-header"><em>Menu item</em></a>
                  <a id="menuinteractive-collapse" class="leftmenu-minuslink"></a>
                  <span class="menuentry-rightborder"></span>
                </div>
                <div id="menuinteractive-inner">
                  <div class="leftmenu-cont-top"></div>
                  <div class="leftmenu-cont-mid">
                    <div class="m-left"><div class="m-right">
                      <div class="leftmenu-cnt">
                        <ul class="mainnav"><li style="position:relative;">
                          <div><a class="menufiller" href="/">Home</a></div>
                          <div><a class="menufiller" href="/server">Server</a></div>
                          <div><a class="menufiller" href="/server/online">Players Online</a></div>
                          <div><a class="menufiller" href="/account">My Account</a></div>
                        </li></ul>
                      </div>
                    </div></div>
                  </div>
                  <div class="leftmenu-cont-bot"></div>
                </div>
              </div>

            </div>
          </div>
        </div>
        <div style="clear: both;"></div>
      </div>
    </td>

    <!-- ===== Main Content Area ===== -->
    <td valign="top">
      <div id="mainwrapper">
      <div id="main">
        <div id="main-content-wrapper">
          <div id="main-content">
            <table cellspacing="0" cellpadding="0" border="0">
              <tr><td>
                <div id="main-top"><div><div><div></div></div></div></div>
              </td></tr>
              <tr><td>
                <div id="contentpadding">
                  <div id="cnt">
                    <div id="cnt-wrapper">
                      <div id="contentcontainer">
                        <table cellspacing="0" cellpadding="0" border="0" width="99%">
                        <tr><td valign="top">
                          <div id="cntmain">
                            <div id="cnt-top"><div><div></div></div></div>
                            <div id="content">
                              <div id="content-left">
                                <div id="content-right">
                                  <div style="padding-right:-15px; margin:-15px;" id="compcont">
                                  <div style="clear:both;display:block;position:relative;width:100%;margin-top:-4px;">

                                    <!-- Breadcrumb -->
                                    <div class="redbannerbg">
                                      <div class="redbannerleft"></div>
                                      <div class="redbannerlabel">
                                        <a href="/">Home</a> &raquo; <a href="/admin">Admin</a> &raquo; <%= typeof title !== 'undefined' ? title : 'Page' %>
                                      </div>
                                      <div class="redbannerright"></div>
                                    </div>

                                    <!-- Flash Messages -->
                                    <% if (typeof flash_success !== 'undefined' && flash_success.length) { %>
                                      <% flash_success.forEach(function(msg) { %>
                                        <div class="flash-message flash-success"><%= msg %></div>
                                      <% }); %>
                                    <% } %>
                                    <% if (typeof flash_error !== 'undefined' && flash_error.length) { %>
                                      <% flash_error.forEach(function(msg) { %>
                                        <div class="flash-message flash-error"><%= msg %></div>
                                      <% }); %>
                                    <% } %>

                                    <!-- Page Content -->
                                    <div class="admin-content-panel">
                                      <%- body %>
                                    </div>

                                  </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                            <div id="cnt-bot"><div><div>&nbsp;</div></div></div>
                          </div>
                        </td></tr>
                        </table>
                      </div>
                    </div>
                  </div>
                  <div style="clear: both; font-size: 1px;">&nbsp;</div>
                  <center>
                    <div id="copyright">
                      <div id="blizzlogo-bot">
                        <img alt="" border="0" src="<%= tp %>/images/bot-blizzlogo.gif" onerror="this.style.display='none';"/>
                      </div>
                      <span class="textlinks"><small>
                        &copy; <%= new Date().getFullYear() %> <b><%= siteTitle %></b> |
                        Powered by MaNGOSWebV5 | AzerothCore 3.3.5a
                      </small></span><br/><br/><br/>
                    </div>
                  </center>
                </div>
              </td></tr>
              <tr><td>
                <div id="main-bottom"><div><div></div></div></div>
              </td></tr>
            </table>
          </div>
        </div>
        <div style="position: relative; z-index: 10;">
          <img style="position: absolute; top: -445px; left: -243px;" alt="statue" src="<%= tp %>/images/statue.png" onerror="this.style.display='none';"/>
        </div>
      </div>
      </div>
    </td>
  </tr>
  </table>
  </div>
  </div>
</div>
</td></tr>
</table>
</center>

<div id="ironframe" style="z-index: 11;"></div>
<div id="pageend"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js" type="text/javascript"></script>
</body>
</html>
