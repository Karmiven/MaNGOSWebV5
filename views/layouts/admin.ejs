<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Admin Panel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="admin-body">
  <div class="d-flex">
    <!-- Sidebar -->
    <nav class="admin-sidebar" id="adminSidebar">
      <div class="sidebar-header">
        <a href="/" class="text-decoration-none">
          <h5 class="text-gold mb-0"><i class="fas fa-crown me-2"></i>MWv5 Admin</h5>
        </a>
      </div>
      <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link" href="/admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/news"><i class="fas fa-newspaper"></i> News</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/chartools"><i class="fas fa-hat-wizard"></i> Characters</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/shop"><i class="fas fa-store"></i> Shop</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/donate"><i class="fas fa-hand-holding-usd"></i> Donate</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/vote"><i class="fas fa-vote-yea"></i> Vote Sites</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/faq"><i class="fas fa-question-circle"></i> FAQ</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/menus"><i class="fas fa-bars"></i> Menus</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/regkeys"><i class="fas fa-key"></i> Reg Keys</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/gamemail"><i class="fas fa-envelope"></i> Game Mail</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/banlist"><i class="fas fa-ban"></i> Ban List</a></li>
        <hr class="border-secondary mx-3">
        <li class="nav-item"><a class="nav-link" href="/admin/siteconfig"><i class="fas fa-cog"></i> Site Config</a></li>
        <% if (typeof user !== 'undefined' && user && user.isSuperAdmin) { %>
          <li class="nav-item"><a class="nav-link" href="/admin/realms"><i class="fas fa-server"></i> Realms</a></li>
        <% } %>
        <li class="nav-item"><a class="nav-link" href="/admin/errorlog"><i class="fas fa-bug"></i> Error Log</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/info"><i class="fas fa-info-circle"></i> System Info</a></li>
        <hr class="border-secondary mx-3">
        <li class="nav-item"><a class="nav-link" href="/"><i class="fas fa-arrow-left"></i> Back to Site</a></li>
      </ul>
    </nav>

    <!-- Main content -->
    <div class="admin-content flex-grow-1">
      <nav class="navbar navbar-dark bg-dark-subtle px-4 py-2">
        <button class="btn btn-sm btn-outline-secondary d-md-none" onclick="document.getElementById('adminSidebar').classList.toggle('show')">
          <i class="fas fa-bars"></i>
        </button>
        <span class="navbar-text ms-auto">
          <i class="fas fa-user me-1"></i> <%= user ? user.username : 'Admin' %>
        </span>
      </nav>

      <div class="p-4">
        <% if (typeof flash_success !== 'undefined' && flash_success.length) { %>
          <% flash_success.forEach(msg => { %>
            <div class="alert alert-success alert-dismissible fade show">
              <i class="fas fa-check-circle me-2"></i><%= msg %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% }) %>
        <% } %>

        <% if (typeof flash_error !== 'undefined' && flash_error.length) { %>
          <% flash_error.forEach(msg => { %>
            <div class="alert alert-danger alert-dismissible fade show">
              <i class="fas fa-exclamation-circle me-2"></i><%= msg %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% }) %>
        <% } %>

        <%- body %>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
