<%
  var tp = typeof themePath !== 'undefined' ? themePath : '/themes/wotlk';
%>
<!-- Blizzard-style footer (matches V4 body_footer.php) -->
<div id="blizzlogo-bot" style="position:relative; display:block; text-align:center; top:0; z-index:500;">
  <img src="<%= tp %>/images/blizzard-logo.gif" alt="" style="border:0;"
       onerror="this.style.display='none';">
</div>

<div id="copyright" style="display:block; position:relative; top:10px; color:#8e8e8e; text-align:center; padding-bottom:20px;">
  <span class="textlinks" style="display:table; position:relative; text-align:center; padding-left:10px; top:15px; left:auto; z-index:400;">
    &copy; <%= new Date().getFullYear() %>
    <a href="/" style="font-size:11px; color:#ffb019; font-weight:bold; text-decoration:none;">
      <%= typeof siteConfig !== 'undefined' && siteConfig.site_title ? siteConfig.site_title : 'MaNGOSWebV5' %>
    </a> |
    Powered by <a href="#" style="font-size:11px; color:#ffb019; font-weight:bold; text-decoration:none;">MaNGOSWebV5</a> |
    AzerothCore 3.3.5a
  </span>
</div>
